{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/)(?!.*\\.html$).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/claude.js": { "maxDuration": 60 },
    "api/daily-fortune.js": { "maxDuration": 30 },
    "api/validate-saju.js": { "maxDuration": 15 }
  }
}
